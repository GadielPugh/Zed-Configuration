{
    // =========================
    // Editor Appearance
    // =========================
    "agent_servers": {
        "gemini": {
            "type": "registry",
        },
        "codex-acp": {
            "type": "registry",
        },
    },
    "agent_ui_font_size": 15.0,
    "buffer_font_family": "Fira Code",
    "tab_size": 4,
    "toolbar": {
        // "breadcrumbs": true,
        // "quick_actions": true,
        // "selections_menu": true,
        // "agent_review": true,
        "quick_actions": false,
    },
    "colorize_brackets": true,
    "show_signature_help_after_edits": true,
    "icon_theme": "Material Icon Theme",
    "project_panel": {
        //"hide_hidden": true,
        "hide_root": true,
        "default_width": 400,
        //"sticky_scroll": false,
        "indent_guides": {
            "show": "never",
        },
    },
    "disable_ai": false,
    "inlay_hints": {
        "enabled": true,
        "show_other_hints": true,
        "show_parameter_hints": false,
        "show_type_hints": false,
        "show_value_hints": true,
    },
    "ui_font_size": 15,
    "buffer_font_size": null,

    "buffer_font_features": {
        "calt": true, // ligatures
    },
    "lsp_document_colors": "border",
    "wrap_guides": [79],
    "show_edit_predictions": true,

    // Theme & Colors
    "theme": {
        "mode": "system",
        "light": "One Light",
        "dark": "Aura Dark",
    },
    "theme_overrides": {
        "Aura Dark": {
            "editor.document_highlight.read_background": "#00000000",
            "editor.document_highlight.write_background": "#00000000",
            "border.variant": "#15141C",
            "border": "#15141C",
            "title_bar.background": "#15141C",
            // "panel.background": "#15141C",
            "panel.focused_border": "#4E466E",
            "players": [
                {
                    "cursor": "#BD9DFF",
                },
            ],
            "syntax": {
                "comment": {
                    "font_style": "italic",
                },
                "comment.doc": {
                    "font_style": "italic",
                },
            },
        },
    },
    "title_bar": {
        // "show_onboarding_banner": false,
        "show_project_items": false,
        "show_branch_name": false,
        //"show_user_menu": false,
    },
    "tab_bar": {
        "show": false,
    },
    "file_finder": {
        "modal_max_width": "xlarge",
    },
    "outline_panel": {
        "default_width": 300,
    },
    "gutter": {
        "min_line_number_digits": 0,
    },

    // =========================
    // Editor Behavior
    // =========================
    "autosave": {
        "after_delay": { "milliseconds": 500 },
    },
    "format_on_save": "on",
    "restore_on_startup": "last_session",
    "show_completions_on_input": true,

    // =========================
    // AI & Assistant Features
    // =========================
    "agent": {
        "button": true,
        "flexible": true,
        "play_sound_when_agent_done": "always",
        "inline_assistant_model": {
            "provider": "zed.dev",
            "model": "claude-sonnet-4-thinking",
        },
        "default_model": {
            "enable_thinking": true,
            "provider": "google",
            "model": "gemini-2.5-flash",
        },
    },
    "edit_predictions": {
        "provider": "zed",
        "mode": "eager",
        "enabled_in_text_threads": false,
        "copilot": {
            "proxy": null,
            "proxy_no_verify": null,
        },
    },

    // =========================
    // Git Integration
    // =========================
    "git": {
        "inline_blame": { "enabled": false },
    },

    // =========================
    // Language-Specific Settings
    // =========================
    "languages": {
        "Python": {
            "formatter": {
                "external": {
                    "command": "black",
                    "arguments": ["-", "--skip-string-normalization"],
                },
            },
            "format_on_save": "on",
        },
        // Rust
        "Rust": {
            "formatter": {
                "external": {
                    "command": "rustfmt",
                    "arguments": [],
                },
            },
            "format_on_save": "on",
        },
    },

    // =========================
    // LSP (Language Server Protocol) for Rust
    // =========================
    "lsp": {
        "rust-analyzer": {
            "initialization_options": {
                "check": {
                    "command": "clippy", // rust-analyzer.check.command (default: "check")
                },
                "imports": {
                    "merge": { "glob": false },
                    "granularity": {
                        "enforce": true,
                        "group": "module",
                    },
                },
                "inlayHints": {
                    "maxLength": null,
                    "lifetimeElisionHints": {
                        "enable": "skip_trivial",
                        "useParameterNames": true,
                    },
                    "closureReturnTypeHints": {
                        "enable": "always",
                    },
                },
            },
        },
    },

    // =========================
    // Privacy & Telemetry
    // =========================
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
}
