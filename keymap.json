// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "context": "Editor",
        "bindings": {
            "cmd-alt-l": "editor::Format",
            "cmd-shift-r": "editor::Rename",
            "cmd-d": "editor::DuplicateLineDown",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "cmd-1": "workspace::ToggleLeftDock",
            "cmd-2": "workspace::ToggleRightDock",
            "cmd-r": ["task::Spawn", { "task_name": "r/python" }],
            "cmd-alt-r": ["task::Spawn", { "task_name": "r/rust" }],
            "cmd-t": "workspace::ToggleBottomDock",
            "cmd-shift-t": "workspace::NewTerminal",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "alt-cmd-b": "workspace::ToggleRightDock"
        }
    }
]
